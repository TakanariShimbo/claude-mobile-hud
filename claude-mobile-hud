#!/usr/bin/env bash
# claude-mobile-hud — dispatcher CLI
#
# subcommands:
#   hub / pair / run / resume / list-sessions / rotate-token / help

set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
CMD="${1:-help}"
shift || true

case "$CMD" in
    hub)
        # Hub daemon を起動。`hub/package.json` の `start` script (`tsx --env-file-if-exists=.env
        # src/index.ts`) を foreground で exec する。--env-file-if-exists により hub/.env が
        # 無いリポジトリ初期セットアップ時でもエラーにならず default で起動できる。
        if [[ ! -d "$ROOT/hub/node_modules" ]]; then
            echo "hub/node_modules not found. Run 'npm --prefix hub ci' first." >&2
            exit 1
        fi
        exec npm --prefix "$ROOT/hub" start --silent -- "$@"
        ;;
    pair)
        # Phone とのペアリング QR を表示。`pair lan` = LAN 経由 (host IPv4 を auto-detect)、
        # `pair ts` = Tailscale 経由 (`ts.net` の 100.x address)。引数なしは `lan` 既定。
        # 実装は hub/src/pair.ts (Phase 3 §5)。
        MODE="${1:-lan}"
        shift || true
        case "$MODE" in
            lan|ts) ;;
            *)
                echo "Usage: claude-mobile-hud pair <lan|ts>" >&2
                exit 1
                ;;
        esac
        if [[ ! -d "$ROOT/hub/node_modules" ]]; then
            echo "hub/node_modules not found. Run 'npm --prefix hub ci' first." >&2
            exit 1
        fi
        exec npm --prefix "$ROOT/hub" run --silent "pair:$MODE" -- "$@"
        ;;
    run)
        # Claude Code セッションを起動 (safe / yolo モード)。
        #
        # - cwd は呼び出し元のものをそのまま継承する (history slug が一致するよう、
        #   $ROOT に cd しない)。
        # - `.mcp.runtime.json` を bridge/ 配下に動的生成して `--mcp-config` で渡す。
        #   user-scope (`~/.claude.json`) の MCP entry には依存しない独立構成。
        # - `--dangerously-load-development-channels server:channel` で Bridge が emit する
        #   `notifications/claude/channel*` を claude に届ける gate を開ける
        #   (Claude 2.x でも flag は受理される、`--help` から隠れただけ)。
        # - `--session-id <uuid>` で claude の履歴 slug を確定する。Bridge には別途
        #   `.mcp.runtime.json` の `env.BRIDGE_SESSION_ID` で同じ UUID を inject する
        #   (wrapper が session_id の single source of truth — AD-12)。
        MODE="${1:-}"
        shift || true
        usage_run() {
            cat >&2 <<USAGE
Usage: claude-mobile-hud run <safe|yolo> [-- claude args...]
  safe  Permission Relay 有効 (Phone で verdict)
  yolo  --dangerously-skip-permissions (Permission Relay 無効)
USAGE
            exit 1
        }
        case "$MODE" in safe|yolo) ;; *) usage_run ;; esac

        # P2-1 of review: 後段の `nc -z ... 2>/dev/null` は `nc: command not found` を握りつぶす
        # ので、nc が無い PC で「Hub not running」という誤メッセージが出てしまう。必須コマンドを
        # 先に明示 verify して actionable なエラーにする。Ubuntu では全て default で入るので
        # 通常 silent path。
        for bin in nc uuidgen claude node; do
            command -v "$bin" >/dev/null 2>&1 || {
                echo "missing required command: $bin (install it or check PATH)" >&2
                exit 1
            }
        done

        HUB_BRIDGE_PORT="${HUB_BRIDGE_PORT:-8787}"
        if ! nc -z -w 1 127.0.0.1 "$HUB_BRIDGE_PORT" 2>/dev/null; then
            echo "Hub not running on 127.0.0.1:$HUB_BRIDGE_PORT. Start it with: claude-mobile-hud hub" >&2
            exit 1
        fi

        SESSION_ID=$(uuidgen)
        echo "[session] $SESSION_ID" >&2

        BRIDGE_DIR="$ROOT/bridge"
        TSX_BIN="$BRIDGE_DIR/node_modules/.bin/tsx"
        BRIDGE_ENTRY="$BRIDGE_DIR/src/index.ts"
        if [[ ! -x "$TSX_BIN" ]]; then
            echo "tsx not found at $TSX_BIN. Run 'npm install' under bridge/ first." >&2
            exit 1
        fi
        MCP_CONFIG_FILE="$BRIDGE_DIR/.mcp.runtime.json"
        # 動的生成: server 名 = `channel` (`--dangerously-load-development-channels server:channel`
        # と一致させる)。`npx -y` 不要 (bridge に tsx 同梱)。
        # - `"type": "stdio"`: Claude Code 2.x は省略時の type 推測が不安定なので明示。
        # - `env.BRIDGE_SESSION_ID`: wrapper の UUID を Bridge に直接渡す (AD-12 の single source
        #   of truth)。Bridge は /proc を歩かず env を読むだけで session_id を得る。claude には
        #   `--session-id $SESSION_ID` で同じ値を渡すので、claude の履歴 slug と Hub の register
        #   が完全に一致する。
        #
        # P1-1 of review: heredoc に変数を直接埋め込むと $TSX_BIN/$BRIDGE_ENTRY のパスに `"` や
        # `\` が含まれた瞬間 JSON が壊れる (現状は固定パスで実害無いが防御コード)。`node -e` で
        # JSON.stringify を経由させ、JSON エスケープを処理系に任せる。
        node -e 'const fs=require("node:fs");fs.writeFileSync(process.argv[1],JSON.stringify({mcpServers:{channel:{type:"stdio",command:process.argv[2],args:[process.argv[3]],env:{BRIDGE_SESSION_ID:process.argv[4]}}}}))' \
            "$MCP_CONFIG_FILE" "$TSX_BIN" "$BRIDGE_ENTRY" "$SESSION_ID"

        EXTRA_FLAGS=()
        if [[ "$MODE" == "yolo" ]]; then
            EXTRA_FLAGS+=("--dangerously-skip-permissions")
        fi

        exec claude \
            --mcp-config "$MCP_CONFIG_FILE" \
            --session-id "$SESSION_ID" \
            --dangerously-load-development-channels server:channel \
            "${EXTRA_FLAGS[@]}" \
            "$@"
        ;;
    list-sessions)
        # cwd-scoped session listing。`~/.claude/projects/<encoded-cwd>/*.jsonl` を
        # 列挙する。encoding は cwd の `/` を `-` に置換した形 (claude のローカル規約)。
        CWD="$(pwd)"
        ENCODED="${CWD//\//-}"
        DIR="${HOME}/.claude/projects/${ENCODED}"
        if [[ ! -d "$DIR" ]]; then
            echo "no claude sessions for $CWD" >&2
            echo "  (expected dir: $DIR)" >&2
            exit 1
        fi
        # 最終更新時刻 (mtime) 降順 + uuid + サイズ + 1 行目テキスト先頭 60 文字を表示。
        shopt -s nullglob
        SESSIONS=("$DIR"/*.jsonl)
        if [[ ${#SESSIONS[@]} -eq 0 ]]; then
            echo "no claude sessions for $CWD" >&2
            exit 1
        fi
        # mtime 降順に並べ、列構成: "MM-DD HH:MM  <size> <uuid>  <first-line preview>"
        for f in "${SESSIONS[@]}"; do
            mtime=$(stat -c '%Y' "$f")
            printf '%s\t%s\n' "$mtime" "$f"
        done | sort -rn | while IFS=$'\t' read -r mtime f; do
            uuid="$(basename "$f" .jsonl)"
            size="$(stat -c '%s' "$f")"
            ts="$(date -d "@$mtime" '+%m-%d %H:%M')"
            # 1 行目 JSONL から user 入力の先頭を抜く (best effort、failure 時は省略)。
            preview="$(head -1 "$f" 2>/dev/null \
                | node -e 'try{const o=JSON.parse(require("fs").readFileSync(0,"utf8"));process.stdout.write((o.message?.content?.[0]?.text || o.content || o.text || "").toString().replace(/\s+/g," ").slice(0,60));}catch(e){}' 2>/dev/null || true)"
            printf '%s  %8s  %s  %s\n' "$ts" "$size" "$uuid" "$preview"
        done
        ;;
    resume)
        # cwd-scoped resume picker。list-sessions を fzf 風に出して 1 件選び、その
        # session_id を `run safe` 経路に流して `claude --resume <uuid>` で起動する。
        CWD="$(pwd)"
        ENCODED="${CWD//\//-}"
        DIR="${HOME}/.claude/projects/${ENCODED}"
        if [[ ! -d "$DIR" ]]; then
            echo "no claude sessions for $CWD" >&2
            exit 1
        fi
        shopt -s nullglob
        SESSIONS=()
        while IFS= read -r f; do
            SESSIONS+=("$f")
        done < <(ls -1t "$DIR"/*.jsonl 2>/dev/null)
        if [[ ${#SESSIONS[@]} -eq 0 ]]; then
            echo "no claude sessions for $CWD" >&2
            exit 1
        fi
        echo "Recent sessions for $CWD (most recent first):" >&2
        for i in "${!SESSIONS[@]}"; do
            f="${SESSIONS[$i]}"
            uuid="$(basename "$f" .jsonl)"
            ts="$(date -r "$f" '+%m-%d %H:%M')"
            printf '  [%d] %s  %s\n' "$((i + 1))" "$ts" "$uuid" >&2
        done
        printf 'Pick [1-%d] (default 1): ' "${#SESSIONS[@]}" >&2
        read -r choice
        choice="${choice:-1}"
        if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#SESSIONS[@]} )); then
            echo "invalid choice: $choice" >&2
            exit 1
        fi
        target="$(basename "${SESSIONS[$((choice - 1))]}" .jsonl)"
        echo "[resume] $target" >&2
        # `run safe` と同じ wiring。ただし新規 session_id 生成ではなく既存 uuid を渡し、
        # claude には `--resume <uuid>` も付ける。`--session-id` は同じ uuid を再使用。
        BRIDGE_DIR="$ROOT/bridge"
        TSX_BIN="$BRIDGE_DIR/node_modules/.bin/tsx"
        BRIDGE_ENTRY="$BRIDGE_DIR/src/index.ts"
        MCP_CONFIG_FILE="$BRIDGE_DIR/.mcp.runtime.json"
        HUB_BRIDGE_PORT="${HUB_BRIDGE_PORT:-8787}"
        if ! nc -z -w 1 127.0.0.1 "$HUB_BRIDGE_PORT" 2>/dev/null; then
            echo "Hub not running on 127.0.0.1:$HUB_BRIDGE_PORT. Start it first." >&2
            exit 1
        fi
        node -e 'const fs=require("node:fs");fs.writeFileSync(process.argv[1],JSON.stringify({mcpServers:{channel:{type:"stdio",command:process.argv[2],args:[process.argv[3]],env:{BRIDGE_SESSION_ID:process.argv[4]}}}}))' \
            "$MCP_CONFIG_FILE" "$TSX_BIN" "$BRIDGE_ENTRY" "$target"
        exec claude \
            --mcp-config "$MCP_CONFIG_FILE" \
            --session-id "$target" \
            --resume "$target" \
            --dangerously-load-development-channels server:channel \
            "$@"
        ;;
    rotate-token)
        # Phase 3 AD-07: hub/.env の HUB_TOKEN を新規 32 hex 文字に書き換える。
        # Hub の自動再起動はしない (現実行中 session を巻き込むため)、書き換え後に
        # ユーザが手動で Hub を restart するワークフロー。
        ENV_FILE="$ROOT/hub/.env"
        if [[ ! -f "$ENV_FILE" ]]; then
            echo "hub/.env not found at $ENV_FILE" >&2
            echo "  (cp hub/.env.example hub/.env first)" >&2
            exit 1
        fi
        if ! command -v openssl >/dev/null 2>&1; then
            echo "openssl not found (needed for token generation)" >&2
            exit 1
        fi
        NEW_TOKEN="$(openssl rand -hex 16)"
        # in-place 編集。`HUB_TOKEN=*` の行を新値で置換、無ければ末尾追加。
        if grep -qE '^HUB_TOKEN=' "$ENV_FILE"; then
            # sed -i with portable BRE; `&` の置換問題を避けるため delimiter を `|` に。
            sed -i "s|^HUB_TOKEN=.*|HUB_TOKEN=$NEW_TOKEN|" "$ENV_FILE"
        else
            printf '\nHUB_TOKEN=%s\n' "$NEW_TOKEN" >> "$ENV_FILE"
        fi
        echo "[rotate-token] HUB_TOKEN updated in $ENV_FILE" >&2
        echo "  new value: $NEW_TOKEN" >&2
        # Hub プロセス検出 (kill しないが、ユーザに restart を促す)。
        if pgrep -f "hub/src/index.ts" >/dev/null 2>&1 \
           || pgrep -f "hub.*src/index.ts" >/dev/null 2>&1; then
            echo "  Hub is running. Restart it for the new token to take effect." >&2
            echo "    (e.g. Ctrl-C in the Hub terminal, then 'npm --prefix hub start')" >&2
        fi
        echo "  Phone Settings の token も再 pair する必要があります。" >&2
        ;;
    help|--help|-h)
        cat <<EOF
claude-mobile-hud — PC の Claude Code をモバイル/HUD から操作する

USAGE:
    claude-mobile-hud <command> [args...]

COMMANDS:
    hub                    Hub daemon を起動
    pair [lan|ts]          phone とペアリングするための QR を表示
    run [safe|yolo]        Claude Code セッションを起動
    resume                 cwd-scoped session resume picker
    list-sessions          cwd-scoped session listing
    rotate-token           Hub の X-Token を再生成
    help                   このメッセージ
EOF
        ;;
    *)
        echo "Unknown command: $CMD" >&2
        echo "Run 'claude-mobile-hud help' for usage." >&2
        exit 1
        ;;
esac
