# Hub の環境変数。`hub/.env` にコピーして値を埋めると `npm start` / `npm run pair` の
# 両方で自動 load される (Node 22+ の `--env-file-if-exists=.env` 経由)。`.env` は .gitignore。

# Phone↔Hub の認証用トークン (NFR-20)。
# `pair` CLI の QR にも埋め込まれ、Phone 側 SettingsDialog から auto-fill される。
# 任意のランダム文字列 (`openssl rand -hex 16` などで生成)。
HUB_TOKEN=your-secret-token-here

# Phone 向け HTTP/SSE のポート。default 8788。
# HUB_HTTP_PORT=8788

# Bridge 向け NDJSON TCP のポート (loopback)。default 8787。
# HUB_BRIDGE_PORT=8787

# SSE keep-alive 間隔 (ms)。default 15000。
# HUB_SSE_KEEPALIVE_MS=15000

# pair CLI で NIC 自動判定を回避して直接 host を指定する場合。
# `en*` prefix の誤検出脱出口 (P2-F of 5-6 review)。
# HUB_PAIR_HOST=192.168.1.10

# StructuredLog のレベル。DEBUG / INFO / WARN / ERROR。default INFO。
# HUB_LOG_LEVEL=INFO
