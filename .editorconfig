root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
indent_size = 4

[*.{ts,tsx,js,jsx,json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[gradlew]
indent_style = space
indent_size = 4

[gradle/wrapper/gradle-wrapper.properties]
indent_size = 4
