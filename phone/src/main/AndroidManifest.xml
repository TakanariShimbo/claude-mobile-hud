<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- docs/03 §9.4.1 / §9.4.4: FGS types (data_sync ×3 + microphone), RECORD_AUDIO, BLUETOOTH_CONNECT。 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        tools:targetApi="34" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"
        tools:targetApi="34" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- docs/03 §9.4.2: CXR-L app の bindService 透過 (Android 11+ package visibility 対策)。 -->
    <queries>
        <package android:name="com.rokid.sprite.global.aiapp" />
    </queries>

    <application
        android:name=".PhoneApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Phone">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Phone"
            android:windowSoftInputMode="adjustNothing|stateHidden">
            <!-- docs/03 §9.4.3: adjustNothing で IME 二重補正回避 + stateHidden で起動時キーボード抑制。 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- docs/03 §3.3 / §9.4.1: 4 FGS の service 層。 -->
        <service
            android:name=".service.ChannelService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        <service
            android:name=".service.GlassConnectionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        <service
            android:name=".service.MicForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone" />
        <service
            android:name=".service.VerdictDispatchService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- docs/03 §3.8: 通知シェード経由 verdict 受け口。 -->
        <receiver
            android:name=".service.PermissionActionReceiver"
            android:exported="false" />
    </application>

</manifest>
